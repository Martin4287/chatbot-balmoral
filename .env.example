# ====================================
# Chatbot Balmoral - Variables de Entorno
# ====================================
# Copiá este archivo como .env y completá con tus datos reales
# cp .env.example .env

# --- UltraMSG (WhatsApp Gateway) ---
# Obtené estos datos en: https://ultramsg.com → Tu instancia → Settings
ULTRAMSG_INSTANCE_ID=tu_instance_id_aqui
ULTRAMSG_TOKEN=tu_token_aqui

# --- Google Gemini (IA) ---
# Obtené tu API key en: https://aistudio.google.com/apikey
GEMINI_API_KEY=tu_api_key_de_gemini_aqui

# --- Servidor ---
PORT=3000

# --- Google Drive (Carta del restaurante) ---
# Link público del PDF de la carta
CARTA_PDF_URL=https://drive.google.com/file/d/1TmmIuRXzHFhAoG0zbxL4rZxhCY0uNQd8/view?usp=drive_link
